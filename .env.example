# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_SECRET=your-super-secret-key-minimum-32-characters

# --- Backend API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Database (PostgreSQL) ---
POSTGRES_DB=policybazar
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Welcome@2026
DATABASE_URL=postgresql+asyncpg://postgres:Welcome%402026@localhost:5432/policybazar

# --- Redis (caching and Celery task queue) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- OpenAI (GPT-3.5-turbo for free tier) ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Tavily Search API (live market comparison) ---
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# --- Stripe (leave empty for mock/development mode) ---
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here

# --- JWT Authentication ---
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# --- AWS S3 (optional for document storage) ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]

# --- Frontend (used by frontend/.env) ---
VITE_API_URL=/api
